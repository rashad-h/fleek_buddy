# Copy to .env and fill one provider key.

# Pick a default provider alias: gemini | qwen
VLM_PROVIDER=gemini

# Or set an explicit LiteLLM model string:
# VLM_MODEL=gemini/gemini-3.5-flash
# VLM_MODEL=gemini/gemini-flash-latest
# VLM_MODEL=dashscope/qwen-vl-max
# VLM_MODEL=openrouter/qwen/qwen2.5-vl-72b-instruct

# Gemini (Google AI Studio): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Qwen via DashScope: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=

# Optional: OpenRouter for Qwen / other VLMs
OPENROUTER_API_KEY=
