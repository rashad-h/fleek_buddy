# --- LLM (provider-agnostic via LiteLLM) -------------------------------------
# Model format is "provider/model". Swap providers by editing these lines only.
LLM_MODEL=anthropic/claude-sonnet-5
# Alternatives: anthropic/claude-opus-4-8  |  openai/gpt-5.1
LLM_FALLBACK_MODEL=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Database ----------------------------------------------------------------
# docker compose overrides host to the `db` service; this value is for running
# the app directly on your host. Note the async driver: postgresql+asyncpg.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
