# Root env — passed to the backend container by docker compose.
# Copy to .env and add your API key: cp .env.example .env

# --- LLM (provider-agnostic via LiteLLM) -------------------------------------
# Model format is "provider/model". Swap providers by editing these lines only.
# Recommended: anthropic/claude-sonnet-5 or openai/gpt-5.4-mini
# Higher quality/cost: anthropic/claude-opus-4-8 or openai/gpt-5.6-terra
# Faster/cheaper: anthropic/claude-haiku-4-5-20251001
# OpenRouter: openrouter/deepseek/deepseek-v4-flash
LLM_MODEL=
LLM_FALLBACK_MODEL=

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Merchant video cataloging (Vision VLM) ----------------------------------
# Required for /merchant Gemini analysis. Also set in Vision/vlm/.env if running
# describe_crops.py directly.
GEMINI_API_KEY=

# Optional overrides when the API runs outside the repo root (e.g. Docker):
# VISION_ROOT=/vision
# MERCHANT_JOBS_DIR=/app/data/merchant_jobs

# --- Database ----------------------------------------------------------------
# docker compose overrides this to point at the `db` service; this value is only
# used when running the backend directly on your host.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/app
